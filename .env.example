# Client-side Supabase config (required in production; use .env.local for development)
# Use Supabase MCP: get_project_url, get_publishable_keys to populate these

VITE_SUPABASE_PROJECT_ID=your-project-id
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Edge Functions (server-side only - set in Supabase Dashboard > Edge Functions > Secrets)
# These are NEVER exposed to the client. Do not add them to .env or .env.local.
# SUPABASE_URL=https://your-project-id.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
